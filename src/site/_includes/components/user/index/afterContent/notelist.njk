{%- set excluded = ["/", "/付费/", "/关于/", "/简历/"] -%}
{%- set articleCount = 0 -%}
{%- for note in collections.note -%}
  {%- if excluded.indexOf(note.url) === -1 -%}
    {%- set articleCount = articleCount + 1 -%}
  {%- endif -%}
{%- endfor -%}
<section class="dg-notelist">
  <nav class="dg-notelist-nav">
    <a class="dg-notelist-nav-link" href="/关于/">关于</a>
    <a class="dg-notelist-nav-link" href="/付费/">付费</a>
    <a class="dg-notelist-nav-link" href="/简历/">简历</a>
  </nav>
  <div class="dg-notelist-header">
    <h2 class="dg-notelist-title">所有文章</h2>
    <span class="dg-notelist-count">{{ articleCount }}</span>
  </div>
  <div class="dg-notelist-body">
    {%- for note in collections.note -%}
      {%- if excluded.indexOf(note.url) === -1 -%}
    <a class="dg-notelist-card" href="{{ note.url }}">
      <span class="dg-notelist-card-name">{% if note.data.title %}{{ note.data.title }}{% else %}{{ note.fileSlug }}{% endif %}</span>
      {%- if note.data["dg-note-properties"] and note.data["dg-note-properties"].created -%}
      <span class="dg-notelist-card-date">{{ note.data["dg-note-properties"].created }}</span>
      {%- endif -%}
    </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>
